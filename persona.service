[Unit]
Description=RPi Persona Simulator Daemon
After=network.target

[Service]
ExecStart=/usr/bin/python3 /home/villa/persona.py --web
WorkingDirectory=/home/villa
StandardOutput=inherit
StandardError=inherit
Restart=always
User=villa
AmbientCapabilities=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
